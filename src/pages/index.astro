---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
import { siteConfig, topics, withBase } from '../config';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const featuredPosts = posts.filter((post) => post.data.featured);
const archivePosts = (featuredPosts.length >= 3 ? featuredPosts : posts).slice(0, 3);
const transmissionPosts = posts.slice(0, 4);
---

<BaseLayout bodyClass="lab-page">
  <div class="lab-home" data-lab-home>
    <aside class="scene-rail" aria-hidden="true">
      <span class="scene-rail__number">01</span>
      <span class="scene-rail__line"><i></i></span>
      <span class="scene-rail__label">PORTAL</span>
    </aside>

    <section class="lab-chapter portal-chapter" data-scene="0" aria-labelledby="portal-title">
      <div class="portal-copy" data-depth="0.6">
        <span class="lab-kicker"><i></i> PERSONAL FIELD LAB / 2026</span>
        <h1 id="portal-title">
          <span>驴驴小侠</span>
          <span>把经历变成系统</span>
        </h1>
        <p>{siteConfig.heroDescription}</p>
        <div class="portal-actions">
          <a class="lab-button lab-button--solid" href="#archive" data-magnetic>进入档案舱 <span>↘</span></a>
          <a class="lab-button" href={withBase('/about/')} data-magnetic>读取人物档案</a>
        </div>
      </div>

      <div class="portal-core" data-depth="1.1" aria-hidden="true">
        <div class="portal-core__orbit portal-core__orbit--one"></div>
        <div class="portal-core__orbit portal-core__orbit--two"></div>
        <div class="portal-core__mark"><span>驴</span><small>LLX</small></div>
        <i class="portal-core__beam"></i>
      </div>

      <figure class="memory-card" data-depth="0.85">
        <div class="memory-card__media">
          <img src={withBase(siteConfig.portrait)} alt="驴驴小侠毕业主题人物肖像" />
        </div>
        <figcaption>
          <span>IDENTITY / 001</span>
          <strong>内容 · 电商 · AI · 代码</strong>
          <small>持续实践，持续记录</small>
        </figcaption>
      </figure>

      <div class="portal-topics" aria-label="博客主题">
        {topics.map((topic, index) => (
          <span><i>{String(index + 1).padStart(2, '0')}</i>{topic.label}</span>
        ))}
      </div>

      <a class="chapter-scroll" href="#archive" aria-label="继续浏览">
        <span>SCROLL TO ENTER</span><i></i>
      </a>
    </section>

    <section class="lab-chapter archive-chapter" id="archive" data-scene="1" aria-labelledby="archive-title">
      <header class="chapter-heading" data-reveal>
        <span class="lab-kicker"><i></i> 02 / SELECTED ARCHIVE</span>
        <h2 id="archive-title">悬浮档案舱</h2>
        <p>拖动面板浏览文章。每一份记录都是一次真实项目留下的坐标。</p>
      </header>

      <div class="archive-deck" data-archive-stage tabindex="0" aria-label="精选文章轮播，使用左右方向键切换">
        {archivePosts.map((post, index) => (
          <a
            class="archive-panel"
            href={withBase(`/blog/${post.id}/`)}
            data-archive-card
            data-panel-index={index}
            aria-label={`阅读文章：${post.data.title}`}
          >
            <div class="archive-panel__screen">
              <span class="archive-panel__code">NOTE / {String(index + 1).padStart(2, '0')}</span>
              <span class={`archive-panel__category accent-${post.data.accent}`}>{post.data.category}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <div class="archive-panel__meta">
                <time datetime={post.data.publishedAt.toISOString()}>
                  {post.data.publishedAt.toLocaleDateString('zh-CN')}
                </time>
                <span>OPEN FILE ↗</span>
              </div>
            </div>
            <span class="archive-panel__edge" aria-hidden="true"></span>
          </a>
        ))}
      </div>

      <div class="archive-console" data-reveal>
        <div>
          <button type="button" data-deck-prev aria-label="上一篇文章">←</button>
          <span data-deck-count>01 / {String(archivePosts.length).padStart(2, '0')}</span>
          <button type="button" data-deck-next aria-label="下一篇文章">→</button>
        </div>
        <span class="archive-console__track"><i data-deck-progress></i></span>
        <small>DRAG / SWIPE / ARROW KEYS</small>
      </div>
    </section>

    <section class="lab-chapter build-chapter" data-scene="2" aria-labelledby="build-title">
      <header class="chapter-heading chapter-heading--split" data-reveal>
        <div>
          <span class="lab-kicker"><i></i> 03 / THE LAB</span>
          <h2 id="build-title">原型实验室</h2>
        </div>
        <p>这里不是成果陈列柜，而是让想法变成工作流、工具和产品的生产现场。</p>
      </header>

      <div class="lab-modules">
        {projects.map((project, index) => (
          <article class="lab-module" data-reveal data-tilt>
            <div class="lab-module__top">
              <span class="lab-module__index">0{index + 1}</span>
              <span class="lab-module__status"><i></i>{project.status}</span>
            </div>
            <div>
              <span class="lab-module__icon">{project.icon}</span>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
            </div>
            <ul>
              {project.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>
            <footer>
              <span>{project.tags.slice(0, 2).join(' / ')}</span>
              <span>BUILD {project.year}</span>
            </footer>
          </article>
        ))}
      </div>

      <a class="lab-button lab-button--quiet" href={withBase('/projects/')} data-magnetic>查看全部项目 <span>↗</span></a>
    </section>

    <section class="lab-chapter transmission-chapter" data-scene="3" aria-labelledby="transmission-title">
      <header class="chapter-heading" data-reveal>
        <span class="lab-kicker"><i></i> 04 / TRANSMISSIONS</span>
        <h2 id="transmission-title">最近传输日志</h2>
      </header>

      <div class="transmission-list">
        {transmissionPosts.map((post, index) => (
          <a class="transmission-row" href={withBase(`/blog/${post.id}/`)} data-reveal data-magnetic>
            <span class="transmission-row__index">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <span>{post.data.category} / {post.data.publishedAt.toLocaleDateString('zh-CN')}</span>
              <h3>{post.data.title}</h3>
            </div>
            <p>{post.data.description}</p>
            <span class="transmission-row__arrow">↗</span>
          </a>
        ))}
      </div>

      <a class="lab-button" href={withBase('/blog/')} data-magnetic>进入全部文章</a>
    </section>

    <section class="lab-chapter contact-chapter" data-scene="4" aria-labelledby="contact-title">
      <div class="contact-terminal" data-reveal>
        <span class="lab-kicker"><i></i> 05 / OPEN CHANNEL</span>
        <h2 id="contact-title">一起做点<br />真实发生的事</h2>
        <p>关于内容、电商、AI、代码，或者一个还没有名字的新想法。</p>
        <div class="contact-terminal__links">
          {siteConfig.emails.map((email) => <a href={`mailto:${email}`} data-magnetic>{email}<span>↗</span></a>)}
          <a href={siteConfig.cmsUrl} target="_blank" rel="noreferrer" data-magnetic>WRITE / PAGES CMS<span>↗</span></a>
        </div>
      </div>
      <div class="contact-orbit" aria-hidden="true"><span>LLX</span><i></i><i></i></div>
      <footer class="lab-footer">
        <span>© {new Date().getFullYear()} {siteConfig.name}</span>
        <span>DESIGNED AS AN INTERACTIVE FIELD LAB</span>
        <a href={siteConfig.socials.github} target="_blank" rel="noreferrer">GITHUB ↗</a>
      </footer>
    </section>
  </div>

  <script is:inline>
    const sceneLabels = ['PORTAL', 'ARCHIVE', 'LAB', 'TRANSMISSIONS', 'CONTACT'];
    const stage = document.querySelector('[data-archive-stage]');
    const cards = [...document.querySelectorAll('[data-archive-card]')];
    const previous = document.querySelector('[data-deck-prev]');
    const next = document.querySelector('[data-deck-next]');
    const counter = document.querySelector('[data-deck-count]');
    const progress = document.querySelector('[data-deck-progress]');
    let position = 0;
    let dragStart = 0;
    let dragPosition = 0;
    let dragged = false;

    const clamp = (value, minimum, maximum) => Math.min(Math.max(value, minimum), maximum);

    const renderDeck = (animate = true) => {
      const cardWidth = Math.min(innerWidth * 0.76, 720);
      cards.forEach((card, index) => {
        const distance = index - position;
        const absolute = Math.abs(distance);
        card.style.setProperty('--panel-x', `${distance * cardWidth * 0.58}px`);
        card.style.setProperty('--panel-y', `${absolute * 34}px`);
        card.style.setProperty('--panel-z', `${absolute * -150}px`);
        card.style.setProperty('--panel-rotate', `${distance * -8}deg`);
        card.style.setProperty('--panel-scale', `${Math.max(0.78, 1 - absolute * 0.09)}`);
        card.style.setProperty('--panel-opacity', `${Math.max(0.2, 1 - absolute * 0.36)}`);
        card.style.zIndex = String(20 - Math.round(absolute * 4));
        card.classList.toggle('is-active', Math.round(position) === index);
        card.classList.toggle('is-dragging', !animate);
      });
      const active = clamp(Math.round(position), 0, cards.length - 1);
      if (counter) counter.textContent = `${String(active + 1).padStart(2, '0')} / ${String(cards.length).padStart(2, '0')}`;
      progress?.style.setProperty('--deck-progress', `${((active + 1) / cards.length) * 100}%`);
    };

    const moveDeck = (direction) => {
      position = clamp(Math.round(position) + direction, 0, cards.length - 1);
      renderDeck();
    };

    previous?.addEventListener('click', () => moveDeck(-1));
    next?.addEventListener('click', () => moveDeck(1));
    stage?.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') moveDeck(-1);
      if (event.key === 'ArrowRight') moveDeck(1);
    });

    stage?.addEventListener('pointerdown', (event) => {
      dragStart = event.clientX;
      dragPosition = position;
      dragged = false;
      stage.setPointerCapture(event.pointerId);
      stage.classList.add('is-grabbing');
    });
    stage?.addEventListener('pointermove', (event) => {
      if (!stage.hasPointerCapture(event.pointerId)) return;
      const delta = event.clientX - dragStart;
      dragged = Math.abs(delta) > 7;
      position = clamp(dragPosition - delta / Math.min(innerWidth * 0.5, 430), 0, cards.length - 1);
      renderDeck(false);
    });
    stage?.addEventListener('pointerup', (event) => {
      if (stage.hasPointerCapture(event.pointerId)) stage.releasePointerCapture(event.pointerId);
      position = clamp(Math.round(position), 0, cards.length - 1);
      stage.classList.remove('is-grabbing');
      renderDeck();
    });
    stage?.addEventListener('click', (event) => {
      if (dragged) event.preventDefault();
    }, true);

    const chapters = [...document.querySelectorAll('[data-scene]')];
    const sceneNumber = document.querySelector('.scene-rail__number');
    const sceneLabel = document.querySelector('.scene-rail__label');
    const sceneLine = document.querySelector('.scene-rail__line i');
    const sceneObserver = new IntersectionObserver((entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (!visible) return;
      const index = Number(visible.target.getAttribute('data-scene') || 0);
      document.body.dataset.activeScene = String(index);
      if (sceneNumber) sceneNumber.textContent = String(index + 1).padStart(2, '0');
      if (sceneLabel) sceneLabel.textContent = sceneLabels[index] || '';
      sceneLine?.style.setProperty('--scene-progress', `${((index + 1) / chapters.length) * 100}%`);
    }, { threshold: [0.28, 0.5, 0.7] });
    chapters.forEach((chapter) => sceneObserver.observe(chapter));

    addEventListener('resize', () => renderDeck(), { passive: true });
    renderDeck();
  </script>
</BaseLayout>
