<div class="aurora-scene lab-world" aria-hidden="true">
  <canvas id="site-webgl"></canvas>
  <div class="lab-world__haze"></div>
  <div class="lab-world__scanlines"></div>
  <div class="lab-world__vignette"></div>
  <div class="lab-world__coordinates"><span>X 23.04</span><span>Y 08.26</span><span>Z LIVE</span></div>
</div>

<script>
  import {
    ACESFilmicToneMapping,
    AdditiveBlending,
    BoxGeometry,
    BufferAttribute,
    BufferGeometry,
    Color,
    EdgesGeometry,
    FogExp2,
    Group,
    IcosahedronGeometry,
    LineBasicMaterial,
    LineSegments,
    Mesh,
    MeshBasicMaterial,
    PerspectiveCamera,
    Points,
    PointsMaterial,
    Scene,
    TorusGeometry,
    TorusKnotGeometry,
    Vector2,
    WebGLRenderer,
  } from 'three';
  import { EffectComposer } from 'three/examples/jsm/postprocessing/EffectComposer.js';
  import { OutputPass } from 'three/examples/jsm/postprocessing/OutputPass.js';
  import { RenderPass } from 'three/examples/jsm/postprocessing/RenderPass.js';
  import { UnrealBloomPass } from 'three/examples/jsm/postprocessing/UnrealBloomPass.js';

  const canvas = document.querySelector<HTMLCanvasElement>('#site-webgl');
  const host = canvas?.closest<HTMLElement>('.lab-world');
  const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && host) {
    try {
      const scene = new Scene();
      scene.fog = new FogExp2('#030607', 0.047);
      const camera = new PerspectiveCamera(46, 1, 0.1, 70);
      const renderer = new WebGLRenderer({
        canvas,
        alpha: false,
        antialias: true,
        powerPreference: 'high-performance',
      });
      renderer.setClearColor('#030607', 1);
      renderer.toneMapping = ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.18;

      const composer = new EffectComposer(renderer);
      const renderPass = new RenderPass(scene, camera);
      const bloomPass = new UnrealBloomPass(new Vector2(1, 1), 1.05, 0.7, 0.12);
      composer.addPass(renderPass);
      composer.addPass(bloomPass);
      composer.addPass(new OutputPass());

      const world = new Group();
      const portal = new Group();
      const archive = new Group();
      const laboratory = new Group();
      const terminal = new Group();
      scene.add(world);
      world.add(portal, archive, laboratory, terminal);

      const geometries: Array<{ dispose: () => void }> = [];
      const materials: Array<{ dispose: () => void }> = [];
      const pointer = new Vector2();
      const pointerTarget = new Vector2();
      const startedAt = performance.now();
      let targetScroll = 0;
      let smoothScroll = 0;
      let pointerEnergy = 0;
      let scrollEnergy = 0;
      let previousScroll = 0;
      let lastPointerX = innerWidth / 2;
      let lastPointerY = innerHeight / 2;
      let frame = 0;
      let active = true;

      camera.position.set(0, 0, 8.2);

      const palette = [new Color('#ff2b85'), new Color('#6cf2df'), new Color('#8f76ff'), new Color('#ffc25f')];
      const mobile = innerWidth < 720;

      const corridorCount = mobile ? 2500 : 6200;
      const corridorPositions = new Float32Array(corridorCount * 3);
      const corridorColors = new Float32Array(corridorCount * 3);
      for (let index = 0; index < corridorCount; index += 1) {
        const offset = index * 3;
        const travel = Math.random();
        const z = 5 - travel * 42;
        const angle = travel * Math.PI * 24 + Math.random() * Math.PI * 2;
        const pulse = 2.2 + Math.sin(travel * Math.PI * 9) * 1.1 + Math.random() * 1.6;
        corridorPositions[offset] = Math.cos(angle) * pulse + Math.sin(travel * 17) * 1.15 + (Math.random() - 0.5) * 0.7;
        corridorPositions[offset + 1] = Math.sin(angle) * pulse * 0.58 + Math.cos(travel * 21) * 0.55 + (Math.random() - 0.5) * 0.6;
        corridorPositions[offset + 2] = z + (Math.random() - 0.5) * 1.4;
        const color = palette[index % palette.length];
        corridorColors[offset] = color.r;
        corridorColors[offset + 1] = color.g;
        corridorColors[offset + 2] = color.b;
      }
      const corridorGeometry = new BufferGeometry();
      corridorGeometry.setAttribute('position', new BufferAttribute(corridorPositions, 3));
      corridorGeometry.setAttribute('color', new BufferAttribute(corridorColors, 3));
      const corridorMaterial = new PointsMaterial({
        size: mobile ? 0.045 : 0.035,
        sizeAttenuation: true,
        transparent: true,
        opacity: 0.78,
        vertexColors: true,
        blending: AdditiveBlending,
        depthWrite: false,
      });
      const corridor = new Points(corridorGeometry, corridorMaterial);
      geometries.push(corridorGeometry);
      materials.push(corridorMaterial);
      world.add(corridor);

      const makeParticleCloud = (group: Group, count: number, colorOffset: number, spread: number) => {
        const positions = new Float32Array(count * 3);
        const colors = new Float32Array(count * 3);
        for (let index = 0; index < count; index += 1) {
          const offset = index * 3;
          const radius = Math.pow(Math.random(), 0.52) * spread;
          const angle = Math.random() * Math.PI * 2;
          positions[offset] = Math.cos(angle) * radius * (0.7 + Math.random() * 0.7);
          positions[offset + 1] = Math.sin(angle) * radius * 0.55 + (Math.random() - 0.5) * 1.3;
          positions[offset + 2] = (Math.random() - 0.5) * 4.5;
          const color = palette[(index + colorOffset) % palette.length];
          colors[offset] = color.r;
          colors[offset + 1] = color.g;
          colors[offset + 2] = color.b;
        }
        const geometry = new BufferGeometry();
        geometry.setAttribute('position', new BufferAttribute(positions, 3));
        geometry.setAttribute('color', new BufferAttribute(colors, 3));
        const material = new PointsMaterial({
          size: mobile ? 0.05 : 0.042,
          transparent: true,
          opacity: 0.88,
          vertexColors: true,
          blending: AdditiveBlending,
          depthWrite: false,
        });
        const cloud = new Points(geometry, material);
        group.add(cloud);
        geometries.push(geometry);
        materials.push(material);
        return cloud;
      };

      const makeRing = (radius: number, tube: number, color: string, opacity: number) => {
        const geometry = new TorusGeometry(radius, tube, 12, 160);
        const material = new MeshBasicMaterial({
          color,
          transparent: true,
          opacity,
          blending: AdditiveBlending,
          depthWrite: false,
        });
        const ring = new Mesh(geometry, material);
        geometries.push(geometry);
        materials.push(material);
        return ring;
      };

      portal.position.set(mobile ? 0 : 1.05, 0.1, 0.4);
      const portalRings = [
        makeRing(1.28, 0.022, '#ff2b85', 0.86),
        makeRing(1.58, 0.012, '#6cf2df', 0.52),
        makeRing(1.9, 0.008, '#8f76ff', 0.28),
      ];
      portalRings.forEach((ring, index) => {
        ring.rotation.set(index * 0.42, index * 0.22, index * 0.6);
        portal.add(ring);
      });
      const portalCoreGeometry = new IcosahedronGeometry(0.82, 2);
      const portalCoreMaterial = new MeshBasicMaterial({
        color: '#ff4b9e',
        wireframe: true,
        transparent: true,
        opacity: 0.42,
        blending: AdditiveBlending,
      });
      const portalCore = new Mesh(portalCoreGeometry, portalCoreMaterial);
      geometries.push(portalCoreGeometry);
      materials.push(portalCoreMaterial);
      portal.add(portalCore);
      const portalCloud = makeParticleCloud(portal, mobile ? 560 : 1450, 0, 3.8);

      const helixMaterial = new LineBasicMaterial({
        color: '#ff2b85',
        transparent: true,
        opacity: 0.64,
        blending: AdditiveBlending,
      });
      materials.push(helixMaterial);
      [-1, 1].forEach((direction) => {
        const positions = new Float32Array(220 * 3);
        for (let index = 0; index < 220; index += 1) {
          const progress = index / 219;
          const angle = progress * Math.PI * 5 + (direction > 0 ? Math.PI : 0);
          positions[index * 3] = Math.cos(angle) * (0.42 + progress * 0.52);
          positions[index * 3 + 1] = -1.05 - progress * 4.2;
          positions[index * 3 + 2] = Math.sin(angle) * 0.5;
        }
        const geometry = new BufferGeometry();
        geometry.setAttribute('position', new BufferAttribute(positions, 3));
        const helix = new LineSegments(geometry, helixMaterial);
        portal.add(helix);
        geometries.push(geometry);
      });

      archive.position.set(0.9, 0, -9.4);
      const archiveKnotGeometry = new TorusKnotGeometry(1.55, 0.34, 220, 18, 2, 5);
      const archiveKnotMaterial = new MeshBasicMaterial({
        color: '#8f76ff',
        wireframe: true,
        transparent: true,
        opacity: 0.19,
        blending: AdditiveBlending,
      });
      const archiveKnot = new Mesh(archiveKnotGeometry, archiveKnotMaterial);
      archiveKnot.scale.set(1, 1.35, 1);
      geometries.push(archiveKnotGeometry);
      materials.push(archiveKnotMaterial);
      archive.add(archiveKnot);
      const archiveCloud = makeParticleCloud(archive, mobile ? 720 : 1800, 1, 4.6);

      laboratory.position.set(-0.9, 0, -19.6);
      const labGeometry = new IcosahedronGeometry(2.4, 4);
      const labEdges = new EdgesGeometry(labGeometry, 18);
      const labMaterial = new LineBasicMaterial({
        color: '#6cf2df',
        transparent: true,
        opacity: 0.24,
        blending: AdditiveBlending,
      });
      const labMesh = new LineSegments(labEdges, labMaterial);
      geometries.push(labGeometry, labEdges);
      materials.push(labMaterial);
      laboratory.add(labMesh);
      const labCloud = makeParticleCloud(laboratory, mobile ? 760 : 2100, 3, 5.2);

      terminal.position.set(0.7, -0.2, -30.4);
      const terminalGeometry = new BoxGeometry(3.8, 3.8, 3.8, 3, 3, 3);
      const terminalEdges = new EdgesGeometry(terminalGeometry);
      const terminalMaterial = new LineBasicMaterial({
        color: '#ff2b85',
        transparent: true,
        opacity: 0.3,
        blending: AdditiveBlending,
      });
      const terminalCage = new LineSegments(terminalEdges, terminalMaterial);
      terminalCage.rotation.set(0.4, 0.6, 0.2);
      geometries.push(terminalGeometry, terminalEdges);
      materials.push(terminalMaterial);
      terminal.add(terminalCage);
      const terminalCloud = makeParticleCloud(terminal, mobile ? 580 : 1500, 0, 4.2);

      const streakCount = mobile ? 70 : 180;
      const streakPositions = new Float32Array(streakCount * 6);
      for (let index = 0; index < streakCount; index += 1) {
        const offset = index * 6;
        const x = (Math.random() - 0.5) * 12;
        const y = (Math.random() - 0.5) * 8;
        const z = 4 - Math.random() * 40;
        streakPositions[offset] = x;
        streakPositions[offset + 1] = y;
        streakPositions[offset + 2] = z;
        streakPositions[offset + 3] = x + (Math.random() - 0.5) * 0.7;
        streakPositions[offset + 4] = y - 0.3 - Math.random() * 1.5;
        streakPositions[offset + 5] = z - Math.random() * 0.4;
      }
      const streakGeometry = new BufferGeometry();
      streakGeometry.setAttribute('position', new BufferAttribute(streakPositions, 3));
      const streakMaterial = new LineBasicMaterial({
        color: '#e9ffff',
        transparent: true,
        opacity: 0.28,
        blending: AdditiveBlending,
      });
      const streaks = new LineSegments(streakGeometry, streakMaterial);
      geometries.push(streakGeometry);
      materials.push(streakMaterial);
      world.add(streaks);

      const updateScroll = () => {
        const maxScroll = Math.max(document.documentElement.scrollHeight - innerHeight, 1);
        const nextScroll = scrollY / maxScroll;
        scrollEnergy = Math.min(scrollEnergy + Math.abs(nextScroll - previousScroll) * 14, 1);
        previousScroll = nextScroll;
        targetScroll = nextScroll;
      };

      const updatePointer = (event: PointerEvent) => {
        pointerTarget.set((event.clientX / innerWidth - 0.5) * 2, (event.clientY / innerHeight - 0.5) * 2);
        pointerEnergy += Math.hypot(event.clientX - lastPointerX, event.clientY - lastPointerY) * 0.0018;
        lastPointerX = event.clientX;
        lastPointerY = event.clientY;
      };

      const resize = () => {
        camera.aspect = innerWidth / Math.max(innerHeight, 1);
        camera.updateProjectionMatrix();
        const pixelRatio = Math.min(devicePixelRatio || 1, innerWidth < 720 ? 1.15 : 1.45);
        renderer.setPixelRatio(pixelRatio);
        renderer.setSize(innerWidth, innerHeight, false);
        composer.setPixelRatio(pixelRatio);
        composer.setSize(innerWidth, innerHeight);
        bloomPass.setSize(innerWidth, innerHeight);
        composer.render();
      };

      const render = () => {
        const elapsed = (performance.now() - startedAt) / 1000;
        pointer.lerp(pointerTarget, 0.045);
        smoothScroll += (targetScroll - smoothScroll) * 0.038;
        pointerEnergy *= 0.91;
        scrollEnergy *= 0.9;

        const worldEnergy = Math.min(pointerEnergy + scrollEnergy, 1);
        camera.fov += (46 + scrollEnergy * 4 - camera.fov) * 0.08;
        camera.updateProjectionMatrix();

        camera.position.z = 8.2 - smoothScroll * 39;
        camera.position.x = pointer.x * 0.34 + Math.sin(smoothScroll * Math.PI * 5) * 0.65;
        camera.position.y = -pointer.y * 0.22 + Math.sin(smoothScroll * Math.PI * 4) * 0.28;
        camera.rotation.z = pointer.x * -0.012 + Math.sin(smoothScroll * Math.PI * 6) * 0.016;
        camera.rotation.y = pointer.x * 0.018;

        world.rotation.y = pointer.x * 0.025;
        corridor.rotation.z = elapsed * 0.008 + smoothScroll * 0.9;
        portal.rotation.y = pointer.x * 0.12 + elapsed * 0.035;
        portal.rotation.x = pointer.y * 0.07;
        portalRings.forEach((ring, index) => {
          ring.rotation.z += 0.0017 + index * 0.0008;
          ring.rotation.y += 0.0007 + index * 0.0003;
        });
        portalCore.rotation.x = elapsed * 0.16;
        portalCore.rotation.y = elapsed * 0.22;
        portalCloud.rotation.z = elapsed * -0.014;
        archiveKnot.rotation.x = elapsed * 0.045;
        archiveKnot.rotation.y = elapsed * 0.075 + pointer.x * 0.08;
        archiveCloud.rotation.z = elapsed * 0.009;
        labMesh.rotation.x = elapsed * 0.035 + pointer.y * 0.04;
        labMesh.rotation.y = elapsed * 0.05 + pointer.x * 0.05;
        labCloud.rotation.y = elapsed * -0.01;
        terminalCage.rotation.y = elapsed * 0.06;
        terminalCage.rotation.z = elapsed * 0.025;
        terminalCloud.rotation.z = elapsed * 0.012;
        streaks.position.y = Math.sin(elapsed * 0.34) * 0.22;
        streaks.scale.y = 1 + Math.min(scrollEnergy * 1.8, 0.9);
        streakMaterial.opacity = 0.2 + Math.min(scrollEnergy * 0.28, 0.24);

        bloomPass.strength = 0.88 + Math.min(pointerEnergy, 0.36) + Math.min(scrollEnergy, 0.24) + Math.sin(elapsed * 0.7) * 0.05;
        composer.render();
        host.dataset.threeReady = 'true';
        host.style.setProperty('--world-scroll', `${smoothScroll}`);
        host.style.setProperty('--world-energy', `${worldEnergy}`);
        if (active && !reducedMotion) frame = requestAnimationFrame(render);
      };

      addEventListener('resize', resize, { passive: true });
      addEventListener('scroll', () => {
        updateScroll();
        if (reducedMotion) render();
      }, { passive: true });
      addEventListener('pointermove', updatePointer, { passive: true });
      document.addEventListener('visibilitychange', () => {
        active = !document.hidden;
        if (active && !reducedMotion) {
          cancelAnimationFrame(frame);
          frame = requestAnimationFrame(render);
        }
      });
      addEventListener('pagehide', () => {
        active = false;
        cancelAnimationFrame(frame);
        geometries.forEach((geometry) => geometry.dispose());
        materials.forEach((material) => material.dispose());
        composer.dispose();
        renderer.dispose();
      }, { once: true });

      updateScroll();
      resize();
      render();
    } catch {
      host.dataset.threeFallback = 'true';
    }
  }
</script>
